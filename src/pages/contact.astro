---
import Base from '@layouts/Base.astro';
import PageHeader from '@components/PageHeader.astro';
import MapEmbed from '@components/MapEmbed.astro';
import CateringForm from '@components/CateringForm.astro';
import { business } from '@data/business';
---

<Base
  title="Contact & Hours | Antonio's Italian Market, Juno Beach FL"
  description="Visit Antonio's Italian Market at 12214 US Highway 1, Juno Beach, FL 33408. Call (561) 625-6544, see our hours, get directions, and send a catering inquiry."
  path="/contact"
>
  <PageHeader
    eyebrow="Find us · Call us · Visit us"
    title="Get in touch"
    lead="We're on US-1 in Juno Beach, easy to reach from North Palm Beach, Palm Beach Gardens, and Jupiter. Call ahead for orders and catering, or just stop by the counter."
  />

  <section class="container-x py-12">
    <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr]">
      <!-- Details -->
      <div class="space-y-8">
        <div class="rounded-xl2 border border-ink/10 bg-cream/60 p-6 shadow-card">
          <h2 class="font-display text-2xl text-forest">Visit the market</h2>
          <address class="mt-4 space-y-4 not-italic">
            <p class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 shrink-0 text-wine" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M12 21s7-5.4 7-11a7 7 0 1 0-14 0c0 5.6 7 11 7 11Z"/><circle cx="12" cy="10" r="2.5"/></svg>
              <a class="font-medium hover:text-wine" href={`https://maps.google.com/?q=${encodeURIComponent(business.address.full)}`} target="_blank" rel="noopener noreferrer">{business.address.full}</a>
            </p>
            <p class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 shrink-0 text-wine" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M5 4h3l2 5-2.5 1.5a11 11 0 0 0 5 5L18 18l-1 3-2 0A13 13 0 0 1 3 8z"/></svg>
              <a class="font-semibold text-wine hover:underline" href={business.phoneHref}>{business.phoneDisplay}</a>
            </p>
            <p class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 shrink-0 text-wine" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m4 7 8 6 8-6"/></svg>
              <a class="font-medium hover:text-wine" href={`mailto:${business.email}`}>{business.email}</a>
            </p>
          </address>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href={business.phoneHref} class="btn-wine">Call now</a>
            <a href={business.orderUrl} target="_blank" rel="noopener noreferrer" class="btn-gold">Order Online</a>
          </div>
        </div>

        <div class="rounded-xl2 border border-ink/10 bg-cream/60 p-6 shadow-card">
          <h2 class="font-display text-2xl text-forest">Hours</h2>
          <dl class="mt-4 divide-y divide-ink/8">
            {business.hours.map((h) => (
              <div class="flex justify-between py-2">
                <dt class="text-ink/70">{h.day}</dt>
                <dd class="font-medium text-ink">{h.opens ? `${h.opens} – ${h.closes}` : 'Closed'}</dd>
              </div>
            ))}
          </dl>
        </div>
      </div>

      <!-- Map + form -->
      <div class="space-y-8">
        <MapEmbed />
        <div class="rounded-xl2 border border-ink/10 bg-cream/60 p-6 shadow-card sm:p-8">
          <h2 class="font-display text-2xl text-wine">Catering &amp; event inquiries</h2>
          <p class="prose-warm mt-2">Planning a party? Send the details and we&rsquo;ll get right back to you with a quote.</p>
          <div class="mt-6">
            <CateringForm />
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
