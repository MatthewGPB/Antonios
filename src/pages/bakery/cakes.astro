---
// This page used to be "Custom Cakes". Izzy's no longer offers custom cakes,
// so this URL now redirects to the Izzy's Bakery landing page. Keeping a valid
// file here also prevents stale-copy build errors if the old file lingers in a
// repo after a file upload (GitHub "Upload files" does not delete old files).
const dest = '/bakery';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${dest}`} />
    <link rel="canonical" href={dest} />
    <meta name="robots" content="noindex, follow" />
    <title>Page moved — Izzy's Bakery</title>
  </head>
  <body>
    <p>This page has moved. <a href={dest}>Continue to Izzy&rsquo;s Bakery</a>.</p>
    <script is:inline>window.location.replace('/bakery');</script>
  </body>
</html>
