---
import Base from '@layouts/Base.astro';
import Hero from '@components/Hero.astro';
import ImagePlaceholder from '@components/ImagePlaceholder.astro';
import SectionCTA from '@components/SectionCTA.astro';
import { business } from '@data/business';

const cards = [
  { title: 'Custom Cakes', text: 'Birthday, celebration, and wedding cakes made to order.', href: '/bakery/cakes', img: '/images/izzys-custom-cake.jpg', alt: 'Custom decorated Italian celebration cake from Izzy\u2019s Bakery' },
  { title: 'Pastries & Desserts', text: 'Cannoli, sfogliatelle, tiramisù, cookies & fresh bread.', href: '/bakery/pastries-and-desserts', img: '/images/izzys-cannoli.jpg', alt: 'Tray of fresh cannoli and Italian pastries' },
];
---

<Base
  title="Izzy's Bakery — Fresh Italian Bakery in Juno Beach | Cakes, Cannoli & Bread"
  description="Izzy's Bakery in Juno Beach, FL: custom cakes, cannoli, sfogliatelle, Italian cookies, and fresh-baked bread daily. Inside Antonio's Italian Market on US-1."
  path="/bakery"
  includeBakerySchema={true}
>
  <Hero
    variant="bakery"
    eyebrow="Inside Antonio's · Juno Beach"
    title="Izzy's Bakery"
    subtitle="Our family bakery turns out fresh Italian pastries, custom cakes, cookies by the pound, and warm bread every day. The sweet side of the market."
    imageSrc="/images/izzys-pastry-case.jpg"
    imageAlt="Izzy's Bakery pastry case filled with cannoli, cakes, and cookies"
  >
    <a slot="actions" href="/bakery/cakes" class="btn-wine">Order a Custom Cake</a>
    <a slot="actions" href="/bakery/pastries-and-desserts" class="btn-outline">Browse Pastries</a>
    <a slot="actions" href={business.izzys.phoneHref} class="btn-outline">Call {business.izzys.phoneDisplay}</a>
  </Hero>

  <section class="container-x py-12">
    <div class="grid gap-8 md:grid-cols-2">
      {cards.map((c) => (
        <a href={c.href} class="group flex flex-col overflow-hidden rounded-xl2 border border-berry/15 bg-cream/60 shadow-card transition hover:-translate-y-1 hover:shadow-lift">
          <ImagePlaceholder src={c.img} alt={c.alt} ratio="16/10" variant="bakery" class="rounded-none border-0" />
          <div class="flex flex-1 flex-col p-6">
            <h2 class="font-display text-2xl text-berry">{c.title}</h2>
            <p class="mt-1 flex-1 text-ink/65">{c.text}</p>
            <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-berry">
              See more
              <svg class="h-4 w-4 transition group-hover:translate-x-1" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Cross-link back to Antonio's -->
  <section class="container-x py-8">
    <div class="flex flex-col items-center justify-between gap-4 rounded-xl2 border border-ink/10 bg-forest/5 p-8 text-center sm:flex-row sm:text-left">
      <div>
        <p class="eyebrow mb-2">Part of the family</p>
        <h2 class="font-display text-2xl text-forest">Pair your dessert with dinner from Antonio&rsquo;s</h2>
        <p class="prose-warm mt-2">Grab a tray of prepared meals or cater your party — and let Izzy&rsquo;s handle the sweets.</p>
      </div>
      <div class="flex shrink-0 gap-3">
        <a href="/prepared-meals" class="btn-forest">Prepared Meals</a>
        <a href="/catering" class="btn-outline">Catering</a>
      </div>
    </div>
  </section>

  <div class="py-8">
    <SectionCTA title="Need a cake for the weekend?" text="Custom cakes need about 72 hours' notice — let's start your order." variant="contact" tone="wine" />
  </div>
</Base>
