---
import { business } from '@data/business';
import { primaryNav } from '@data/nav';

const year = new Date().getFullYear();
const flatLinks = primaryNav.flatMap((i) => (i.children ? i.children : [i]));
---

<footer class="mt-24 bg-ink text-cream/85">
  <div class="container-x grid gap-12 py-16 md:grid-cols-[1.4fr_1fr_1fr]">
    <!-- Brand + NAP -->
    <div>
      <div class="flex items-center gap-3">
        <span class="grid h-11 w-11 place-items-center rounded-full border-2 border-gold bg-forest font-display text-xl font-bold text-cream">A</span>
        <div class="leading-tight">
          <span class="block font-display text-2xl font-semibold text-cream">Antonio&rsquo;s</span>
          <span class="block text-[10px] font-semibold uppercase tracking-[0.28em] text-gold">{business.tagline}</span>
        </div>
      </div>
      <p class="mt-5 max-w-sm text-sm leading-relaxed text-cream/70">
        Family-owned Italian market &amp; deli in Juno Beach, Florida. Fresh deli counter,
        house-made sausage, prepared meals, and catering across Palm Beach County.
      </p>
      <div class="mt-6 space-y-1.5 text-sm">
        <p>
          <a class="hover:text-gold" href={`https://maps.google.com/?q=${encodeURIComponent(business.address.full)}`} target="_blank" rel="noopener noreferrer">
            {business.address.full}
          </a>
        </p>
        <p>
          <a class="font-semibold text-gold hover:underline" href={business.phoneHref}>{business.phoneDisplay}</a>
        </p>
        <p>
          <a class="hover:text-gold" href={`mailto:${business.email}`}>{business.email}</a>
        </p>
      </div>
    </div>

    <!-- Explore -->
    <nav aria-label="Footer">
      <h2 class="font-display text-lg text-cream">Explore</h2>
      <ul class="mt-4 space-y-2 text-sm">
        {flatLinks.map((l) => (
          <li><a class="text-cream/75 transition hover:text-gold" href={l.href}>{l.label}</a></li>
        ))}
      </ul>
    </nav>

    <!-- Hours + social -->
    <div>
      <h2 class="font-display text-lg text-cream">Hours</h2>
      <dl class="mt-4 space-y-1 text-sm">
        {business.hours.map((h) => (
          <div class="flex justify-between gap-4 border-b border-cream/10 py-1">
            <dt class="text-cream/70">{h.label}</dt>
            <dd class="text-cream/90">{h.opens ? `${h.opens}–${h.closes}` : 'Closed'}</dd>
          </div>
        ))}
      </dl>
      <div class="mt-6 flex gap-3">
        <a href={business.social.instagram} target="_blank" rel="noopener noreferrer" class="grid h-10 w-10 place-items-center rounded-full border border-cream/20 transition hover:border-gold hover:text-gold" aria-label="Antonio's on Instagram">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="5" />
            <circle cx="12" cy="12" r="4" />
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
          </svg>
        </a>
        <a href={business.orderUrl} target="_blank" rel="noopener noreferrer" class="grid h-10 place-items-center rounded-full border border-cream/20 px-4 text-xs font-semibold uppercase tracking-wider transition hover:border-gold hover:text-gold">
          Order Online
        </a>
      </div>
    </div>
  </div>

  <div class="border-t border-cream/10">
    <div class="container-x flex flex-col items-center justify-between gap-2 py-6 text-xs text-cream/60 sm:flex-row">
      <p>&copy; {year} {business.legalName}. All rights reserved.</p>
      <p>
        Home of <span class="text-gold">Izzy&rsquo;s Bakery</span> &middot; Juno Beach &middot; North Palm Beach
      </p>
    </div>
  </div>
</footer>
