---
import { business } from '@data/business';

// A keyless Google Maps embed using the public "q=" output mode.
// Works with no API key. If you later add a Maps Embed API key, swap the src for:
// https://www.google.com/maps/embed/v1/place?key=YOUR_KEY&q=ENCODED_ADDRESS
const query = encodeURIComponent(`${business.name}, ${business.address.full}`);
const src = `https://www.google.com/maps?q=${query}&output=embed`;
---

<div class="overflow-hidden rounded-xl2 border border-ink/10 shadow-card">
  <iframe
    title={`Map to ${business.name}, ${business.address.full}`}
    src={src}
    width="100%"
    height="380"
    style="border:0;"
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
    allowfullscreen
  ></iframe>
</div>
