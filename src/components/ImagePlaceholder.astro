---
/**
 * Smart image slot.
 *
 * If a real photo exists at `public{src}` (e.g. public/images/hero-deli-counter.jpg),
 * this renders that photo. If the file isn't there yet, it renders a labeled gray
 * placeholder showing the suggested filename — so you can add photos gradually and
 * nothing ever breaks.
 *
 * To add a photo: drop a file into the `public/images/` folder using the exact
 * filename shown on the placeholder (case-sensitive, e.g. hero-deli-counter.jpg).
 */
import fs from 'node:fs';
import path from 'node:path';

export interface Props {
  src: string;          // e.g. "/images/hero-deli-counter.jpg"
  alt: string;
  ratio?: string;       // e.g. "16/9", "4/3", "1/1", "3/4"
  variant?: 'deli' | 'bakery';
  class?: string;
}

const { src, alt, ratio = '4/3', variant = 'deli', class: className = '' } = Astro.props;
const filename = src.split('/').pop();

// Does a real photo exist for this slot? (checked at build time)
let hasImage = false;
try {
  hasImage = fs.existsSync(path.join(process.cwd(), 'public', src));
} catch {
  hasImage = false;
}

const palette =
  variant === 'bakery'
    ? 'from-berry/15 to-caramel/20 text-berry'
    : 'from-forest/10 to-gold/15 text-forest';
---

{hasImage ? (
  <figure
    class={`overflow-hidden rounded-xl2 border border-ink/10 ${className}`}
    style={`aspect-ratio:${ratio};`}
  >
    <img src={src} alt={alt} loading="lazy" decoding="async" class="h-full w-full object-cover" />
  </figure>
) : (
  <figure
    class={`group relative overflow-hidden rounded-xl2 border border-ink/10 bg-gradient-to-br ${palette} ${className}`}
    style={`aspect-ratio:${ratio};`}
  >
    <div class="pointer-events-none absolute inset-0 opacity-50" aria-hidden="true">
      <svg class="h-full w-full" preserveAspectRatio="none" viewBox="0 0 100 100">
        <line x1="0" y1="0" x2="100" y2="100" stroke="currentColor" stroke-width="0.25" />
        <line x1="100" y1="0" x2="0" y2="100" stroke="currentColor" stroke-width="0.25" />
      </svg>
    </div>
    <figcaption class="absolute inset-0 flex flex-col items-center justify-center gap-1 p-4 text-center">
      <svg class="mb-1 h-8 w-8 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <rect x="3" y="4" width="18" height="16" rx="2" />
        <circle cx="8.5" cy="9.5" r="1.5" />
        <path d="M21 16l-5-5L5 20" />
      </svg>
      <span class="text-sm font-semibold leading-tight">{alt}</span>
      <code class="mt-1 rounded bg-ink/5 px-2 py-0.5 text-[11px] font-medium opacity-70">{filename}</code>
    </figcaption>
  </figure>
)}
