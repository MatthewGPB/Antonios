---
import ImagePlaceholder from '@components/ImagePlaceholder.astro';

export interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  imageSrc: string;
  imageAlt: string;
  variant?: 'deli' | 'bakery';
}

const { eyebrow, title, subtitle, imageSrc, imageAlt, variant = 'deli' } = Astro.props;
const accent = variant === 'bakery' ? 'text-berry' : 'text-forest';
---

<section class="relative overflow-hidden">
  <!-- atmospheric backdrop -->
  <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
    <div class={`absolute -left-24 -top-24 h-80 w-80 rounded-full blur-3xl ${variant === 'bakery' ? 'bg-berry/10' : 'bg-forest/10'}`}></div>
    <div class="absolute -right-16 top-32 h-72 w-72 rounded-full bg-gold/10 blur-3xl"></div>
  </div>

  <div class="container-x grid items-center gap-10 py-14 md:py-20 lg:grid-cols-2 lg:gap-16">
    <div class="reveal">
      {eyebrow && <p class="eyebrow mb-4">{eyebrow}</p>}
      <h1 class={`font-display text-4xl font-semibold sm:text-5xl lg:text-6xl ${accent}`}>{title}</h1>
      {subtitle && <p class="prose-warm mt-5">{subtitle}</p>}
      <div class="mt-8 flex flex-wrap gap-3">
        <slot name="actions" />
      </div>
      <slot name="below" />
    </div>

    <div class="reveal" style="animation-delay:120ms">
      <div class="relative">
        <div class={`absolute -inset-3 -z-10 rounded-[1.6rem] ${variant === 'bakery' ? 'bg-caramel/20' : 'bg-gold/20'}`} aria-hidden="true"></div>
        <ImagePlaceholder src={imageSrc} alt={imageAlt} ratio="4/3" variant={variant} class="shadow-lift" />
      </div>
    </div>
  </div>
</section>
