---
import { business } from '@data/business';
import { primaryNav } from '@data/nav';

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath === href || currentPath.startsWith(href + '/');

const orderUrl = business.orderUrl;
---

<header class="sticky top-0 z-50 border-b border-ink/10 bg-cream/90 backdrop-blur supports-[backdrop-filter]:bg-cream/80">
  <div class="container-x flex h-[68px] items-center justify-between gap-4">
    <!-- Wordmark (drop a real logo into this <a> later) -->
    <a href="/" class="group flex items-center gap-3" aria-label={`${business.name} — home`}>
      <span class="grid h-10 w-10 place-items-center rounded-full border-2 border-gold bg-forest font-display text-xl font-bold text-cream">A</span>
      <span class="leading-none">
        <span class="block font-display text-xl font-semibold tracking-tight text-forest">Antonio&rsquo;s</span>
        <span class="block text-[10px] font-semibold uppercase tracking-[0.28em] text-wine">{business.tagline}</span>
      </span>
    </a>

    <!-- Desktop nav (xl and up) -->
    <nav class="hidden items-center gap-1 xl:flex" aria-label="Primary">
      {primaryNav.map((item) =>
        item.children ? (
          <div class="group relative">
            <a
              href={item.href}
              class:list={[
                'flex items-center gap-1 rounded-full px-3 py-2 text-[13px] font-semibold uppercase tracking-wider transition',
                isActive(item.href) ? 'text-wine' : 'text-ink/75 hover:text-forest',
              ]}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
              <svg class="h-3 w-3 opacity-60" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M3 4.5 6 7.5 9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <div class="invisible absolute left-0 top-full min-w-[15rem] translate-y-1 rounded-xl border border-ink/10 bg-cream p-2 opacity-0 shadow-lift transition group-hover:visible group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
              {item.children.map((c) => (
                <a href={c.href} class="block rounded-lg px-3 py-2 text-sm font-medium text-ink/80 hover:bg-forest hover:text-cream">{c.label}</a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={item.href}
            class:list={[
              'rounded-full px-3 py-2 text-[13px] font-semibold uppercase tracking-wider transition',
              isActive(item.href) ? 'text-wine' : 'text-ink/75 hover:text-forest',
            ]}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        )
      )}
    </nav>

    <div class="flex items-center gap-2">
      <a href={orderUrl} target="_blank" rel="noopener noreferrer" class="btn-gold hidden sm:inline-flex">
        Order Online
      </a>

      <!-- Mobile hamburger (below xl) -->
      <button
        type="button"
        id="nav-toggle"
        class="grid h-11 w-11 place-items-center rounded-full border border-ink/15 text-forest xl:hidden"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <svg id="icon-open" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round"/></svg>
        <svg id="icon-close" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" stroke-linecap="round"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav panel -->
  <nav
    id="mobile-nav"
    class="hidden border-t border-ink/10 bg-cream xl:hidden"
    aria-label="Mobile"
  >
    <div class="container-x flex flex-col gap-1 py-4">
      {primaryNav.map((item) => (
        <Fragment>
          <a
            href={item.href}
            class:list={[
              'rounded-lg px-3 py-2.5 text-base font-semibold',
              isActive(item.href) ? 'bg-forest text-cream' : 'text-ink/85 hover:bg-ink/5',
            ]}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
          {item.children && (
            <div class="ml-3 flex flex-col gap-0.5 border-l-2 border-gold/40 pl-3">
              {item.children.slice(1).map((c) => (
                <a href={c.href} class="rounded-lg px-3 py-2 text-sm font-medium text-ink/70 hover:bg-ink/5">{c.label}</a>
              ))}
            </div>
          )}
        </Fragment>
      ))}
      <a href={orderUrl} target="_blank" rel="noopener noreferrer" class="btn-gold mt-3">Order Online</a>
      <a href={business.phoneHref} class="btn-outline mt-1">Call {business.phoneDisplay}</a>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const panel = document.getElementById('mobile-nav');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = panel?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(isOpen));
    toggle.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
    iconOpen?.classList.toggle('hidden', isOpen);
    iconClose?.classList.toggle('hidden', !isOpen);
  });
</script>
