---
import type { MenuSection } from '@data/menu';

export interface Props {
  sections: MenuSection[];
  variant?: 'deli' | 'bakery';
}

const { sections, variant = 'deli' } = Astro.props;
const tagColor: Record<string, string> = {
  Signature: 'bg-wine/10 text-wine',
  'House-made': 'bg-forest/10 text-forest',
  Popular: 'bg-gold/20 text-ink',
  Seasonal: 'bg-berry/15 text-berry',
};
const headColor = variant === 'bakery' ? 'text-berry' : 'text-forest';
---

<div class="grid gap-10 md:grid-cols-2">
  {sections.map((section) => (
    <section class="rounded-xl2 border border-ink/10 bg-cream/60 p-6 shadow-card sm:p-8">
      <h3 class={`font-display text-2xl font-semibold ${headColor}`}>{section.title}</h3>
      {section.note && <p class="mt-1 text-sm italic text-ink/55">{section.note}</p>}
      <ul class="mt-5 divide-y divide-ink/8">
        {section.items.map((item) => (
          <li class="flex items-baseline justify-between gap-4 py-3">
            <div>
              <p class="flex flex-wrap items-center gap-2 font-semibold text-ink">
                {item.name}
                {item.tag && (
                  <span class={`rounded-full px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider ${tagColor[item.tag]}`}>{item.tag}</span>
                )}
              </p>
              {item.description && <p class="mt-0.5 text-sm text-ink/60">{item.description}</p>}
            </div>
            {item.price && (
              <span class="shrink-0 font-display text-lg font-semibold text-wine tabular-nums">{item.price}</span>
            )}
          </li>
        ))}
      </ul>
    </section>
  ))}
</div>
