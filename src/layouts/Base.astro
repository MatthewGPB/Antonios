---
import '@fontsource-variable/fraunces';
import '@fontsource-variable/inter';
import '../styles/global.css';

import Seo from '@components/Seo.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';

export interface Props {
  title: string;
  description: string;
  path: string;
  ogImage?: string;
  includeBakerySchema?: boolean;
}

const { title, description, path, ogImage, includeBakerySchema } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Google tag (gtag.js) — GA4 property G-6Z0KVZ0TGF -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-6Z0KVZ0TGF"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-6Z0KVZ0TGF');
    </script>
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="theme-color" content="#1f4d3a" />
    <meta name="google-site-verification" content="1o8JzrBZk58LUpgG-9QyDcNNiKG2EoJRuigRukyvmZ0" />
    <Seo
      title={title}
      description={description}
      path={path}
      ogImage={ogImage}
      includeBakerySchema={includeBakerySchema}
    />
  </head>
  <body class="flex min-h-screen flex-col">
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
