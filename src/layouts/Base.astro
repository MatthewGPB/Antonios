---
import '@fontsource-variable/fraunces';
import '@fontsource-variable/inter';
import '../styles/global.css';

import Seo from '@components/Seo.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';

export interface Props {
  title: string;
  description: string;
  path: string;
  ogImage?: string;
  includeBakerySchema?: boolean;
  includeFloristSchema?: boolean;
}

const { title, description, path, ogImage, includeBakerySchema, includeFloristSchema } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="theme-color" content="#1f4d3a" />
    <meta name="google-site-verification" content="1o8JzrBZk58LUpgG-9QyDcNNiKG2EoJRuigRukyvmZ0" />

    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-5QFSZHHF');</script>
    <!-- End Google Tag Manager -->
    <!-- GA4 (G-6Z0KVZ0TGF) fires through the GTM container above — do not re-add a direct gtag.js snippet here or pageviews will double-count. -->
    <Seo
      title={title}
      description={description}
      path={path}
      ogImage={ogImage}
      includeBakerySchema={includeBakerySchema}
      includeFloristSchema={includeFloristSchema}
    />
  </head>
  <body class="flex min-h-screen flex-col">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-5QFSZHHF"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
